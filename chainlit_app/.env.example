# Local dev for `chainlit run app.py`. Copy to chainlit_app/.env and fill in.
# Needs: gcloud auth application-default login (ADC used to call Agent Engine + the connector).

GOOGLE_CLOUD_PROJECT=project-4382e8df-acc3-437e-9e7
GOOGLE_CLOUD_LOCATION=us-central1

# Deployed agent (Agent Engine) + Agent Identity connector (reused)
AGENT_ENGINE_ID=884190417417928704
OBO_CONNECTOR=projects/project-4382e8df-acc3-437e-9e7/locations/us-central1/connectors/bigquery-3lo
OBO_SCOPE=https://www.googleapis.com/auth/bigquery

# Public base URL of THIS app (used to build the /oauth/callback continue_uri).
# Locally: http://localhost:8080 ; in Cloud Run: the run.app URL.
APP_BASE_URL=http://localhost:8080

# Chainlit session signing secret (any random string locally; Secret Manager in cloud)
CHAINLIT_AUTH_SECRET=change-me-to-a-random-string

# App login via Auth0 (reuse the mcp-toolbox tenant/app)
OAUTH_AUTH0_CLIENT_ID=fJta0a1DB3itvmmo3bddufnZDnfzSlGK
OAUTH_AUTH0_DOMAIN=dev-6d1lsgbv5w63zkmo.us.auth0.com
OAUTH_AUTH0_CLIENT_SECRET=from-secret-manager-auth0-client-secret
